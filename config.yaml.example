server:
  port: "5000"
  api_key: "sk-your-secret-key"

models:
  - name: gpt-4
    provider: openai
    model: gpt-4
    api_key: sk-your-openai-key
    base_url: https://api.openai.com/v1

  - name: claude-sonnet
    provider: anthropic
    model: claude-sonnet-4-20250514
    api_key: sk-your-anthropic-key
    base_url: https://api.anthropic.com

  - name: gpt-5-responses
    provider: responses
    model: gpt-5
    api_key: sk-your-openai-key
    base_url: https://api.openai.com/v1
